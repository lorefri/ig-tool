# Credenziali Instagram (account dedicato, NON il principale)
INSTAGRAM_USERNAME=tuo_username
INSTAGRAM_PASSWORD=tua_password

# Chiave API Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Session ID Instagram (da Chrome → F12 → Application → Cookies → sessionid)
INSTAGRAM_SESSION_ID=

# Pagine Instagram da cui prendere i follower (separate da virgola)
# Consiglio: pagine italiane di NM, business, crescita personale, guadagno online
TARGET_PAGES=frankdelui,robertocipriani_official,networkmarketingitalia,ilsegreto_delsuccesso,crescita_personale_ita

# Obiettivo: corso | sponsorizzazione | entrambi | custom
OBJECTIVE=entrambi

# Strategia: recommended | custom
STRATEGY_TYPE=custom
CUSTOM_DO_FOLLOW=true
CUSTOM_DO_LIKE_POST=false
CUSTOM_DO_LIKE_STORY=false
CUSTOM_DO_DM=true
CUSTOM_DO_UNFOLLOW=true
DAYS_BETWEEN_STEPS=0
DAYS_BEFORE_UNFOLLOW=3

# Limiti giornalieri
MAX_DM_PER_DAY=15
MIN_DELAY_SECONDS=45
MAX_DELAY_SECONDS=180
MAX_FOLLOWS_PER_DAY=30
MAX_LIKES_PER_DAY=30
MAX_STORIES_PER_DAY=20

# Follow-up automatici
MAX_DM_FOLLOWUPS=1
DAYS_BEFORE_FOLLOWUP=5

# Filtri profilo
MIN_FOLLOWERS=50
MAX_FOLLOWERS=100000
MIN_POSTS=3
SKIP_VERIFIED=true
REQUIRE_ITALY=false
BIO_INCLUDE_KEYWORDS=
BIO_EXCLUDE_KEYWORDS=spam,bot

# Orari attivi (0-23)
ACTIVE_HOURS_START=9
ACTIVE_HOURS_END=22
ACTIVE_DAYS=1,2,3,4,5,6,7

# Messaggi
MESSAGE_TONE=informale
MESSAGE_VARIANTS=2

# Notifiche (opzionale)
NOTIFY_ON_REPLY=false
NOTIFY_WEBHOOK=
